{
  "entities": {
    "User": {
      "title": "User",
      "description": "A member of the Falla",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Full name of the user" },
        "email": { "type": "string", "format": "email", "description": "Email address" },
        "role": { "type": "string", "enum": ["admin", "directiva", "delegado_loteria", "delegado_festejos", "fallero"], "description": "User role" },
        "familyId": { "type": "string", "description": "ID of the family this user belongs to" },
        "categoryId": { "type": "string", "description": "ID of the quota category" },
        "isAdult": { "type": "boolean", "description": "Whether the user is an adult" },
        "isFamilyAdmin": { "type": "boolean", "description": "Whether the user is the family administrator" }
      },
      "required": ["name", "email", "role", "categoryId", "isAdult", "isFamilyAdmin"]
    },
    "Family": {
      "title": "Family",
      "description": "A family unit within the Falla",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the family" },
        "representativeId": { "type": "string", "description": "User ID of the family representative" },
        "members": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Array of User IDs belonging to this family"
        }
      },
      "required": ["name", "representativeId", "members"]
    },
    "Category": {
      "title": "Category",
      "description": "A quota category",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the category" },
        "quotaAmount": { "type": "number", "description": "Amount of the quota" }
      },
      "required": ["name", "quotaAmount"]
    },
    "Event": {
      "title": "Event",
      "description": "An event organized by the Falla",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Title of the event" },
        "description": { "type": "string", "description": "Description of the event" },
        "date": { "type": "string", "description": "Date and time of the event in ISO format" },
        "price": { "type": "number", "description": "Price of the event" },
        "attendees": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Array of User IDs attending the event"
        }
      },
      "required": ["title", "description", "date", "price", "attendees"]
    },
    "Lottery": {
      "title": "Lottery",
      "description": "A lottery campaign",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the lottery" },
        "totalTickets": { "type": "number", "description": "Total number of tickets" },
        "assignedToFamily": {
          "type": "object",
          "additionalProperties": { "type": "number" },
          "description": "Map of familyId to number of assigned tickets"
        },
        "soldByFamily": {
          "type": "object",
          "additionalProperties": { "type": "number" },
          "description": "Map of familyId to number of sold tickets"
        }
      },
      "required": ["name", "totalTickets", "assignedToFamily", "soldByFamily"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Collection of users"
    },
    "/families/{familyId}": {
      "schema": { "$ref": "#/entities/Family" },
      "description": "Collection of families"
    },
    "/categories/{categoryId}": {
      "schema": { "$ref": "#/entities/Category" },
      "description": "Collection of quota categories"
    },
    "/events/{eventId}": {
      "schema": { "$ref": "#/entities/Event" },
      "description": "Collection of events"
    },
    "/lotteries/{lotteryId}": {
      "schema": { "$ref": "#/entities/Lottery" },
      "description": "Collection of lotteries"
    }
  }
}
